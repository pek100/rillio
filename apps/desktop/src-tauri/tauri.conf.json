{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rillio",
  "version": "0.1.17",
  "identifier": "com.rillio.desktop",
  "build": {
    "frontendDist": "../../web/build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' www.gstatic.com appleid.cdn-apple.com; style-src 'self' 'unsafe-inline'; style-src-elem 'self' 'unsafe-inline'; style-src-attr 'unsafe-inline'; img-src 'self' data: blob: https: http:; media-src 'self' data: blob: https: http:; font-src 'self' data:; connect-src 'self' data: blob: https: http: ws: wss: ipc: http://ipc.localhost; frame-src 'self' https:; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/nsis-header.bmp",
        "sidebarImage": "installer/nsis-sidebar.bmp"
      },
      "wix": {
        "bannerPath": "installer/wix-banner.bmp",
        "dialogImagePath": "installer/wix-dialog.bmp"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["stremio", "rillio"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/pek100/rillio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQyMTRDQUE4NzA0QUVFQjUKUldTMTdrcHdxTW9VMHZVWWlVSlF1ZEdqUldlQlUvbERpN1kwVEUzMjBhSE54d21RSWtGa2pwTGMK"
    }
  }
}
